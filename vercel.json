{
  "version": 2,
  "framework": null,
  "rewrites": [
    { "source": "/pos", "destination": "/pos.html" },
    { "source": "/owner", "destination": "/owner.html" },
    { "source": "/ownerportal", "destination": "/owner.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/tokoonline", "destination": "/store.html" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
